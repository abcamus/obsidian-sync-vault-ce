{
	"name": "sync-vault",
	"version": "2.1.2",
	"description": "Professional cloud sync & VFS for Obsidian. Features zero-space VFS, 4K streaming, MCP AI engine, and P2P collaboration. Supports Baidu/Aliyun/Quark/WebDAV/S3.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs watch",
		"encrypt": "ts-node tools/encrypt-modules.ts",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"build:dev": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs development",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"release": "npm run version && npm run build && python3 ./tools/release.py",
		"deploy": "python3 ./tools/deploy.py --reload-cmd 'obsidian plugin:reload id=sync-vault-ce'",
		"test": "jest --watchAll=false",
		"checksum": "tsx tools/generate-checksum.ts",
		"verify": "tsx tools/verify-checksum.ts",
		"rebuild": "rm -rf dist/ .cache/ node_modules/ && npm install && npm run build",
		"lint": "eslint .",
		"lint:fix": "eslint --fix ."
	},
	"keywords": [],
	"author": "Camus Qiu/KQ Digital Garden",
	"license": "Proprietary Software License",
	"devDependencies": {
		"@babel/core": "^7.28.5",
		"@babel/preset-env": "^7.28.5",
		"@babel/preset-typescript": "^7.27.1",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.40.0",
		"@eslint/json": "^1.2.0",
		"@types/diff-match-patch": "^1.0.36",
		"@types/jest": "^29.5.14",
		"@types/jsdom": "^21.1.7",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^16.11.6",
		"@types/qrcode": "^1.5.5",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@types/react-icons": "^2.2.7",
		"@types/spark-md5": "^3.0.4",
		"@types/video.js": "^7.3.58",
		"@types/ws": "^8.18.1",
		"babel-jest": "^30.2.0",
		"commander": "^12.1.0",
		"dependency-cruiser": "^17.3.1",
		"esbuild": "^0.25.5",
		"eslint": "^9.14.0",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"javascript-obfuscator": "^4.1.1",
		"jest": "^29.7.0",
		"jiti": "2.6.1",
		"jsdom": "^26.0.0",
		"madge": "^8.0.0",
		"obsidian": "latest",
		"prettier": "^3.6.2",
		"ts-jest": "^29.3.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tslib": "^2.8.1",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.62.1",
		"winston": "^3.17.0"
	},
	"dependencies": {
		"@emotion/react": "^11.13.3",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^6.1.0",
		"@mui/material": "^6.1.1",
		"@noble/hashes": "^1.5.0",
		"diff-match-patch": "^1.0.5",
		"fast-xml-parser": "^5.2.5",
		"hls.js": "^1.6.2",
		"lib0": "^0.2.117",
		"loglevel": "^1.9.2",
		"monkey-around": "^3.0.0",
		"qrcode": "^1.5.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-icons": "^5.5.0",
		"spark-md5": "^3.0.2",
		"yjs": "^13.6.24"
	}
}
